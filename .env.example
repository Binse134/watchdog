# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql+psycopg2://watchdog:watchdog@localhost:5433/watchdog

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Resend (https://resend.com) - for email alerts
RESEND_API_KEY=
ALERTS_FROM_EMAIL=alerts@yourdomain.com

# Local LLM via Ollama (https://ollama.com)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# Used to build links in emails (e.g. password reset)
FRONTEND_URL=http://localhost:3000
